# Supabase (required — all providers)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─────────────────────────────────────────────
# EMBEDDING PROVIDER (pick ONE)
# ─────────────────────────────────────────────
# Options: openai | gemini | fireworks
EMBEDDING_PROVIDER=gemini

# OpenAI (default) — 1536 dims
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini (Google) — 768 dims, padded to 1536
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Fireworks.ai — OpenAI-compatible, 768 dims, padded to 1536
# FIREWORKS_API_KEY=fw-...
# FIREWORKS_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
APP_NAME=Company Brain API
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
AGENT_API_KEY_HEADER=x-api-key
